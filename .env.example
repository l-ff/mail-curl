# App
PORT=3100
HOST=0.0.0.0
MC_KEY=sk-test

# ChatGPT Mail provider, requires API key and set ENABLED=0 to disable
CHATGPT_MAIL_ENABLED=1
CHATGPT_MAIL_API_KEY=
CHATGPT_MAIL_BASE_URL=https://mail.chatgpt.org.uk
CHATGPT_MAIL_TIMEOUT_MS=10000

# 24.email provider, set ENABLED=0 to disable
TWENTY_FOUR_EMAIL_ENABLED=1
TWENTY_FOUR_EMAIL_BASE_URL=https://24.email
TWENTY_FOUR_EMAIL_TIMEOUT_MS=10000

# Generator.email provider, set ENABLED=0 to disable
GENERATOR_EMAIL_ENABLED=1
GENERATOR_EMAIL_BASE_URL=https://generator.email
GENERATOR_EMAIL_TIMEOUT_MS=10000

# Temp-Mail.io provider, set ENABLED=0 to disable
TEMP_MAIL_IO_ENABLED=1
TEMP_MAIL_IO_BASE_URL=https://api.internal.temp-mail.io
TEMP_MAIL_IO_SITE_URL=https://temp-mail.io
TEMP_MAIL_IO_CORS_HEADER=1
TEMP_MAIL_IO_TIMEOUT_MS=10000

# Mail.tm provider, set ENABLED=0 to disable
MAIL_TM_ENABLED=1
MAIL_TM_BASE_URL=https://api.mail.tm
MAIL_TM_SITE_URL=https://mail.tm
MAIL_TM_PASSWORD=
MAIL_TM_TIMEOUT_MS=10000

# Priyo.email provider, set ENABLED=0 to disable
PRIYO_EMAIL_ENABLED=1
PRIYO_EMAIL_BASE_URL=https://priyo.email
PRIYO_EMAIL_TIMEOUT_MS=20000
